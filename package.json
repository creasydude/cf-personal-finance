{
  "name": "cf-personal-finance",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "wrangler pages dev --kv=RATE_CACHE",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "wrangler pages deploy dist",
    "db:init": "wrangler d1 execute personal-finance-db --local --file=migrations/0001_init.sql",
    "db:init:remote": "wrangler d1 execute personal-finance-db --remote --file=migrations/0001_init.sql",
    "seed": "wrangler d1 execute personal-finance-db --local --file=migrations/0002_seed.sql"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.20.0",
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.4.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240806.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "wrangler": "^3.68.0"
  }
}
